    "diagnostics": "warning",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "git": {
    "gutter_debounce": 100,
    "inline_blame": {
      "enabled": true,
      "delay_ms": 800,
      "show_commit_summary": true,
      "min_column": 120,
    },
  },
  "edit_predictions_disabled_in": ["comment", "string"],
  "snippet_sort_order": "none",
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "min_column": 100,
      "max_severity": "warning",
    },
  },
  "lsp": {
    "clangd": {
      "binary": {
        "ignore_system_version": false,
      },
    },
    "dart": {
      "settings": {
        "lineLength": 100,
      },
    },
    "gopls": {
      "initialization_options": {
        "usePlaceholders": true,
        "completionBudget": "500ms",
        "gofumpt": false,
        "codelenses": {
          "run_govulncheck": true,
        },
        "analyses": {
          "shadow": false,
          "unusedvariable": true,
        },
        "staticcheck": true,
        "vulncheck": "Imports",
        "semanticTokens": true,
        "semanticTokenTypes": {
          "string": false,
          "number": false,
        },
        "linksInHover": false,
        "hints": {
          "assignVariableTypes": false,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "rust-analyzer": {
      "binary": {
        "ignore_system_version": true,
      },
      "enable_lsp_tasks": true,
      "initialization_options": {
        "cargo": {
          "extraEnv": {
            "RUSTUP_AUTO_INSTALL": "1",
            "RUST_BACKTRACE": "full",
            "RUSTC_WRAPPER": "sccache",
            "SCCACHE_CACHE_SIZE": "10G",
          },
          "features": "all",
          "allTargets": false,
        },
        "rust": {
          "analyzerTargetDir": true,
        },
        "assist": {
          "emitMustUse": true,
          "preferSelf": true,
        },
        "completion": {
          "fullFunctionSignatures": {
            "enable": true,
          },
          "termSearch": {
            "enable": true,
          },
          "snippets": {
            "custom": {
              "Arc::new": {
                "postfix": "arc",
                "body": ["Arc::new(${receiver})"],
                "requires": "std::sync::Arc",
                "scope": "expr",
              },
              "Some": {
                "postfix": "some",
                "body": ["Some(${receiver})"],
                "scope": "expr",
              },
              "Ok": {
                "postfix": "ok",
                "body": ["Ok(${receiver})"],
                "scope": "expr",
              },
              "Rc::new": {
                "postfix": "rc",
                "body": ["Rc::new(${receiver})"],
                "requires": "std::rc::Rc",
                "scope": "expr",
              },
              "Box::pin": {
                "postfix": "boxpin",
                "body": ["Box::pin(${receiver})"],
                "requires": "std::boxed::Box",
                "scope": "expr",
              },
              "vec!": {
                "postfix": "vec",
                "body": ["vec![${receiver}]"],
                "description": "vec![]",
                "scope": "expr",
              },
            },
          },
        },
        "diagnostics": {
          "styleLints": {
            "enable": true,
          },
          "experimental": {
            "enable": true,
          },
        },
        "hover": {
          "actions": {
            "enable": true,
            "references": {
              "enable": true,
            },
          },
          "memoryLayout": {
            "niches": true,
          },
        },
        "imports": {
          "granularity": {
            "enforce": true,
          },
          "preferNoStd": false,
          "preferPrelude": true,
        },
        "inlayHints": {
          "maxLength": null,
          "bindingModeHints": {
            "enable": true,
          },
          "closureCaptureHints": {
            "enable": true,
          },
          "closureReturnTypeHints": {
            "enable": "with_block",
          },
          "discriminantHints": {
            "enable": "fieldless",
          },
          "genericParameterHints": {
            "lifetime": {
              "enable": true,
            },
            "type": {
              "enable": true,
            },
          },
          "implicitDrops": {
            "enable": true,
          },
          "implicitSizedBoundHints": {
            "enable": true,
          },
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "rangeExclusiveHints": {
            "enable": true,
          },
          "renderColons": false,
        },
        "lens": {
          "enable": true,
          "references": {
            "adt": {
              "enable": true,
            },
            "enumVariant": {
              "enable": true,
            },
            "method": {
              "enable": true,
            },
            "trait": {
              "enable": true,
            },
          },
        },
        "lru": {
          "capacity": 512,
        },
        "notifications": {
          "cargoTomlNotFound": false,
        },
        "rustfmt": {
          "extraArgs": ["--config", "use_field_init_shorthand=true"],
        },
        "check": {
          "command": "clippy",
          "workspace": false,
          "allTargets": false,
          "extraArgs": [
            "--tests",
            "--lib",
            "--bins",
            "--benches",
            "--",
            "-W",
            "clippy::pedantic",
            "-A",
            "clippy::struct_excessive_bools",
            "-A",
            "clippy::case_sensitive_file_extension_comparisons",
            "-A",
            "clippy::missing-fields-in-debug",
            "-A",
            "clippy::trivially-copy-pass-by-ref",
            "-A",
            "clippy::default-trait-access",
            "-A",
            "clippy::match-wildcard-for-single-variants",
            "-A",
            "clippy::explicit-deref-methods",
            "-A",
            "clippy::too-many-lines",
            "-A",
            "clippy::missing-errors-doc",
            "-A",
            "clippy::missing-panics-doc",
            "-A",
            "clippy::must-use-candidate",
            "-A",
            "clippy::wildcard-imports",
            "-W",
            "clippy::nursery",
            "-A",
            "clippy::redundant-pub-crate",
            "-D",
            "clippy::style",
            "-D",
            "clippy::complexity",
            "-D",
            "clippy::perf",
            "-A",
            "clippy::similar-names",
            "-D",
            "clippy::todo",
            "-D",
            "clippy::cargo",
            "-A",
            "clippy::multiple_crate_versions",
            "-A",
            "clippy::cargo-common-metadata",
            "-A",
            "clippy::doc_markdown",
          ],
          "features": "all",
        },
        "checkOnSave": true,
        "semanticHighlighting": {
          "operator": {
            "specialization": {
              "enable": true,
            },
          },
          "punctuation": {
            "enable": true,
            "separate": {
              "macro": {
                "bang": true,
              },
            },
            "specialization": {
              "enable": true,
            },
          },
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "vue": "html",
        },
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            ":class=\"([^\"]*)\"",
            ":class='([^']*)'",
          ],
        },
      },
    },
  },
