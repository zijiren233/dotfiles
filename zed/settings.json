// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
// main default: https://github.com/zed-industries/zed/blob/main/assets/settings/default.json
{
  "search": {
    "include_ignored": true,
    "search_on_input": true,
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/target/.rustc_info.json",
    "**/target/tmp",
    "**/target/debug",
    "**/target/release",
    "**/target/rust-analyzer",
  ],
  "file_scan_inclusions": [".env*"],
  "private_files": [
    "**/.env*",
    "**/*.pem",
    "**/*.key",
    "**/*.cert",
    "**/*.crt",
    "**/secrets.yml",
    "**/*.local",
    "**/*.local.*",
  ],
  "restore_on_startup": "launchpad",
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_project_panel": true,
    "enable_preview_from_file_finder": false,
    "enable_preview_from_multibuffer": true,
    "enable_preview_multibuffer_from_code_navigation": false,
    "enable_preview_file_from_code_navigation": true,
    "enable_keep_preview_on_code_navigation": false,
  },
  "project_panel": {
    "button": true,
    "dock": "left",
    "git_status": true,
    "auto_reveal_entries": true,
    "bold_folder_labels": true,
    "indent_guides": {
      "show": "always",
    },
    "git_status_indicator": true,
  },
  "use_autoclose": true,
  "always_treat_brackets_as_autoclosed": true,
  "git_panel": {
    "button": true,
    "dock": "left",
    "collapse_untracked_diff": true,
    "status_style": "label_color",
    "show_count_badge": true,
    "file_icons": true,
    "tree_view": true,
    "starts_open": false,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": true,
    "show_tab_bar_buttons": true,
  },
  "title_bar": {
    "show_branch_icon": false,
    "show_branch_name": true,
    "show_project_items": true,
    "show_onboarding_banner": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_sign_in": true,
    "show_menus": true,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
    "agent_review": false,
    "code_actions": false,
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
    "line_endings_button": true,
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "auto_update": false,
  "colorize_brackets": true,
  "collaboration_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
  },
  "agent_ui_font_size": 13.0,
  "document_folding_ranges": "on",
  "document_symbols": "on",
  "icon_theme": "Material Icon Theme",
  "language_models": {
    "anthropic": {
      "api_url": "https://obegeiepkdvx.sealoshzh.site",
    },
  },
  "edit_predictions": {
    "provider": "copilot",
  },
  "agent": {
    "enable_feedback": false,
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6-latest",
    },
    "inline_alternatives": [
      {
        "provider": "anthropic",
        "model": "claude-opus-4-6",
      },
    ],
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "ui_font_size": 13.0,
  "buffer_font_size": 12.0,
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Light Hard",
    "dark": "One Dark Pro",
  },
  "buffer_font_family": "Maple Mono Normal NFMono CN",
  "buffer_font_fallbacks": [
    "Maple Mono Normal NF CN",
    "Maple Mono NF",
    "Zed Plex Mono",
  ],
  "buffer_font_features": {
    "calt": true,
    "liga": true,
  },
  "ui_font_family": "Maple Mono Normal NFMono CN",
  "ui_font_fallbacks": [
    "Maple Mono Normal NF CN",
    "Maple Mono NF",
    "Zed Plex Mono",
  ],
  "ui_font_features": {
    "calt": false,
  },
  "terminal": {
    "path_hyperlink_timeout_ms": 10,
    "path_hyperlink_regexes": [
      // Zed default: Python-style diagnostics
      "File \"(?<path>[^\"]+)\", line (?<line>[0-9]+)",
      // VS Code-style fallback: FILE  <path>:<line>:<column>
      "^ +FILE +(?<link>(?<path>.+?)(?::(?<line>[0-9]+)(?::(?<column>[0-9]+))?)?)(?:\\s|$)",
      // Bare path with :line[:column]. No left delimiter requirement, so it still matches inside
      // a hovered "word" like 无关panic：core/relay/.../main_test.go:366.
      "(?<link>(?<path>(?:(?:\\./|\\.\\./|~/|/)[^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+|[A-Za-z0-9_.-][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]*)(?:[/.][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+)+):(?<line>[0-9]+)(?::(?<column>[0-9]+))?)",
      // Bare path with (line[,column]).
      "(?<link>(?<path>(?:(?:\\./|\\.\\./|~/|/)[^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+|[A-Za-z0-9_.-][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]*)(?:[/.][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+)+)[(（](?<line>[0-9]+)(?:[,，]\\s*(?<column>[0-9]+))?[)）])",
      // Quoted textual suffix:
      // "foo", line 12
      // 'foo' on line 12, column 3
      "(?:^|[\\s\\u3000:：])[({\\[<（〔［｛〈《「『【]{0,2}(?<link>[\"'`“‘](?<path>[^\"'`“”‘’]+)[\"'`”’])(?:[,，]?\\s*|[:：]\\s*|\\s+on\\s+)lines?\\s+(?<line>[0-9]+)(?:-[0-9]+)?(?:[,，]?\\s*(?:col(?:umn)?|characters?)\\s+(?<column>[0-9]+)(?:-[0-9]+)?)?",
      // Unquoted textual suffix:
      // foo, line 12
      // foo: line 12, column 3
      "(?:^|[\\s\\u3000:：])[({\\[<（〔［｛〈《「『【]{0,2}(?<link>(?<path>(?:(?:\\./|\\.\\./|~/|/)[^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+|[A-Za-z0-9_.-][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]*)(?:[/.][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+)+))(?:[,，]?\\s*|[:：]\\s*|\\s+on\\s+)lines?\\s+(?<line>[0-9]+)(?:-[0-9]+)?(?:[,，]?\\s*(?:col(?:umn)?|characters?)\\s+(?<column>[0-9]+)(?:-[0-9]+)?)?",
      // #line[:column]
      "(?:^|[\\s\\u3000:：])[({\\[<\"'`（〔［｛〈《「『【“‘]{0,2}(?<link>(?<path>(?:(?:\\./|\\.\\./|~/|/)[^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+|[A-Za-z0-9_.-][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]*)(?:[/.][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+)+)#(?<line>[0-9]+)(?:[:：.](?<column>[0-9]+))?)",
      // [line[:column]] or [line, column]
      "(?:^|[\\s\\u3000:：])[({\\[<\"'`（〔［｛〈《「『【“‘]{0,2}(?<link>(?<path>(?:(?:\\./|\\.\\./|~/|/)[^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+|[A-Za-z0-9_.-][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]*)(?:[/.][^\\s\\u3000:：\"'`#()<>\\[\\]{}（）〔〕［］｛｝〈〉《》「」『』【】“”‘’]+)+)(?:\\s*|[:：]\\s*)[\\[［](?<line>[0-9]+)(?:(?:[,，]\\s*|[:：])(?<column>[0-9]+))?[\\]］])",
    ],
    "cursor_shape": "bar",
    "font_family": "Maple Mono Normal NFMono CN",
    "font_fallbacks": [
      "Maple Mono Normal NF CN",
      "Maple Mono NF",
      "Zed Plex Mono",
    ],
    "font_size": 12,
    "line_height": "standard",
    "font_features": {
      "calt": false,
      "liga": false,
    },
    "env": {
      "GIT_EDITOR": "zed --wait",
    },
  },
  "auto_install_extensions": {
    "bash": true,
    "dart": true,
    "docker-compose": true,
    "dockerfile": true,
    "helm": true,
    "html": true,
    "lua": true,
    "make": true,
    "proto": true,
    "sql": true,
    "swift": true,
    "toml": true,
    "vue": true,
    "xml": true,
    "one-dark-pro": true,
    "material-icon-theme": true,
    "log": true,
    "csv": true,
    "github-actions": true,
    "neocmake": true,
    "live-server": true,
    "git-firefly": true,
    "scss": true,
  },
  "file_types": {
    "JSONC": [
      "**/.zed/**/*.json",
      "**/zed/**/*.json",
      "**/Zed/**/*.json",
      "**/.vscode/**/*.json",
    ],
    "Shell Script": [".env.*"],
    "Dockerfile": ["Dockerfile*"],
    "Helm": [
      "**/templates/**/*.tpl",
      "**/templates/**/*.yaml",
      "**/templates/**/*.yml",
      "**/helmfile.d/**/*.yaml",
      "**/helmfile.d/**/*.yml",
      "**/values*.yaml",
    ],
    "HTML": ["mjml"],
    "Make": ["Makefile*"],
    "GitHub Actions": [".github/workflows/*.yml", ".github/workflows/*.yaml"],
    "Diff": ["dif"],
    "XML": ["rdf", "gpx", "kml"],
    "Git Attributes": ["**/{git,.git,.git/info}/attributes"],
    "Git Config": [
      "*.gitconfig",
      "**/{git,.git/modules,.git/modules/*}/config",
    ],
    "Git Ignore": ["**/{git,.git}/ignore", "**/.git/info/exclude"],
  },
  "semantic_tokens": "combined",
  "auto_signature_help": true,
  "show_signature_help_after_edits": true,
  "hover_popover_delay": 200,
  "scroll_sensitivity": 1.0,
  "fast_scroll_sensitivity": 2.0,
  "vertical_scroll_margin": 4,
  "scroll_beyond_last_line": "vertical_scroll_margin",
  "current_line_highlight": "all",
  "show_whitespaces": "boundary",
  "show_wrap_guides": true,
  "wrap_guides": [100],
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "journal": {
    "hour_format": "hour24",
  },
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": true,
    "toggle_on_modifiers_press": {
      "alt": true,
    },
  },
  "minimap": {
    "show": "always",
    "thumb": "always",
    "current_line_highlight": "line",
  },
  "scrollbar": {
    "diagnostics": "warning",
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "git": {
    "gutter_debounce": 100,
    "inline_blame": {
      "enabled": true,
      "delay_ms": 800,
      "show_commit_summary": true,
      "min_column": 120,
    },
  },
  "edit_predictions_disabled_in": ["comment", "string"],
  "snippet_sort_order": "none",
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "min_column": 100,
      "max_severity": "warning",
    },
  },
  "lsp": {
    "clangd": {
      "binary": {
        "ignore_system_version": false,
      },
    },
    "dart": {
      "settings": {
        "lineLength": 100,
      },
    },
    "gopls": {
      "initialization_options": {
        "usePlaceholders": true,
        "completionBudget": "500ms",
        "gofumpt": false,
        "codelenses": {
          "run_govulncheck": true,
        },
        "analyses": {
          "shadow": false,
          "unusedvariable": true,
        },
        "staticcheck": true,
        "vulncheck": "Imports",
        "semanticTokens": true,
        "semanticTokenTypes": {
          "string": false,
          "number": false,
        },
        "linksInHover": false,
        "hints": {
          "assignVariableTypes": false,
          "compositeLiteralFields": true,
          "compositeLiteralTypes": true,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "rust-analyzer": {
      "binary": {
        "ignore_system_version": true,
      },
      "enable_lsp_tasks": true,
      "initialization_options": {
        "cargo": {
          "extraEnv": {
            "RUSTUP_AUTO_INSTALL": "1",
            "RUST_BACKTRACE": "full",
            "RUSTC_WRAPPER": "sccache",
            "SCCACHE_CACHE_SIZE": "10G",
          },
          "features": "all",
          "allTargets": false,
        },
        "rust": {
          "analyzerTargetDir": true,
        },
        "assist": {
          "emitMustUse": true,
          "preferSelf": true,
        },
        "completion": {
          "fullFunctionSignatures": {
            "enable": true,
          },
          "termSearch": {
            "enable": true,
          },
          "snippets": {
            "custom": {
              "Arc::new": {
                "postfix": "arc",
                "body": ["Arc::new(${receiver})"],
                "requires": "std::sync::Arc",
                "scope": "expr",
              },
              "Some": {
                "postfix": "some",
                "body": ["Some(${receiver})"],
                "scope": "expr",
              },
              "Ok": {
                "postfix": "ok",
                "body": ["Ok(${receiver})"],
                "scope": "expr",
              },
              "Rc::new": {
                "postfix": "rc",
                "body": ["Rc::new(${receiver})"],
                "requires": "std::rc::Rc",
                "scope": "expr",
              },
              "Box::pin": {
                "postfix": "boxpin",
                "body": ["Box::pin(${receiver})"],
                "requires": "std::boxed::Box",
                "scope": "expr",
              },
              "vec!": {
                "postfix": "vec",
                "body": ["vec![${receiver}]"],
                "description": "vec![]",
                "scope": "expr",
              },
            },
          },
        },
        "diagnostics": {
          "styleLints": {
            "enable": true,
          },
          "experimental": {
            "enable": true,
          },
        },
        "hover": {
          "actions": {
            "enable": true,
            "references": {
              "enable": true,
            },
          },
          "memoryLayout": {
            "niches": true,
          },
        },
        "imports": {
          "granularity": {
            "enforce": true,
          },
          "preferNoStd": false,
          "preferPrelude": true,
        },
        "inlayHints": {
          "maxLength": null,
          "bindingModeHints": {
            "enable": true,
          },
          "closureCaptureHints": {
            "enable": true,
          },
          "closureReturnTypeHints": {
            "enable": "with_block",
          },
          "discriminantHints": {
            "enable": "fieldless",
          },
          "genericParameterHints": {
            "lifetime": {
              "enable": true,
            },
            "type": {
              "enable": true,
            },
          },
          "implicitDrops": {
            "enable": true,
          },
          "implicitSizedBoundHints": {
            "enable": true,
          },
          "lifetimeElisionHints": {
            "enable": "skip_trivial",
            "useParameterNames": true,
          },
          "rangeExclusiveHints": {
            "enable": true,
          },
          "renderColons": false,
        },
        "lens": {
          "enable": true,
          "references": {
            "adt": {
              "enable": true,
            },
            "enumVariant": {
              "enable": true,
            },
            "method": {
              "enable": true,
            },
            "trait": {
              "enable": true,
            },
          },
        },
        "lru": {
          "capacity": 512,
        },
        "notifications": {
          "cargoTomlNotFound": false,
        },
        "rustfmt": {
          "extraArgs": ["--config", "use_field_init_shorthand=true"],
        },
        "check": {
          "command": "clippy",
          "workspace": false,
          "allTargets": true,
          // "features": "all",
          "extraArgs": [
            "--",
            "-W",
            "clippy::pedantic",
            "-A",
            "clippy::doc_markdown",
            "-A",
            "clippy::struct_excessive_bools",
            "-A",
            "clippy::case_sensitive_file_extension_comparisons",
            "-A",
            "clippy::missing_fields_in_debug",
            "-A",
            "clippy::trivially_copy_pass_by_ref",
            "-A",
            "clippy::default_trait_access",
            "-A",
            "clippy::match_wildcard_for_single_variants",
            "-A",
            "clippy::explicit_deref_methods",
            "-A",
            "clippy::too_many_lines",
            "-A",
            "clippy::missing_errors_doc",
            "-A",
            "clippy::missing_panics_doc",
            "-A",
            "clippy::must_use_candidate",
            "-A",
            "clippy::wildcard_imports",
            // "-W",
            // "clippy::nursery",
            "-A",
            "clippy::redundant_pub_crate",
            "-D",
            "clippy::style",
            "-D",
            "clippy::complexity",
            "-D",
            "clippy::perf",
            "-A",
            "clippy::similar_names",
            "-D",
            "clippy::todo",
            "-D",
            "clippy::cargo",
            "-A",
            "clippy::multiple_crate_versions",
            "-A",
            "clippy::cargo_common_metadata",
          ],
        },
        "checkOnSave": true,
        "semanticHighlighting": {
          "operator": {
            "specialization": {
              "enable": true,
            },
          },
          "punctuation": {
            "enable": true,
            "separate": {
              "macro": {
                "bang": true,
              },
            },
            "specialization": {
              "enable": true,
            },
          },
        },
      },
    },
    "tailwindcss-language-server": {
      "settings": {
        "includeLanguages": {
          "vue": "html",
        },
        "experimental": {
          "classRegex": [
            "class=\"([^\"]*)\"",
            "class='([^']*)'",
            ":class=\"([^\"]*)\"",
            ":class='([^']*)'",
          ],
        },
      },
    },
  },
  "languages": {
    "C": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "formatter": "language_server",
      "format_on_save": "on",
      "document_symbols": "on",
      "document_folding_ranges": "on",
      "tab_size": 2,
    },
    "C++": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "formatter": "language_server",
      "format_on_save": "on",
      "document_symbols": "on",
      "document_folding_ranges": "on",
      "tab_size": 2,
    },
    "CSS": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "format_on_save": "on",
      "language_servers": ["tailwindcss-intellisense-css", "..."],
    },
    "Dart": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "formatter": "language_server",
      "format_on_save": "on",
      "document_symbols": "on",
      "document_folding_ranges": "on",
      "preferred_line_length": 100,
      "tab_size": 2,
    },
    "Diff": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "tab_size": 2,
      "hard_tabs": false,
    },
    "Dockerfile": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "formatter": "language_server",
      "format_on_save": "on",
      "document_symbols": "on",
      "document_folding_ranges": "on",
    },
    "Go": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
      },
      "formatter": [
        {
          "external": {
            "command": "golangci-lint",
            "arguments": ["fmt", "--stdin"],
          },
        },
        {
          "code_action": "source.organizeImports",
        },
      ],
      "format_on_save": "on",
      "document_symbols": "on",
      "document_folding_ranges": "on",
      "preferred_line_length": 100,
      "hard_tabs": true,
      "tab_size": 4,
    },
    "Helm": {
      "colorize_brackets": true,
      "indent_guides": {
        "background_coloring": "indent_aware",
