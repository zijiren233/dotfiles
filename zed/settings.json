  "auto_install_extensions": {
    "bash": true,
    "dart": true,
    "docker-compose": true,
    "dockerfile": true,
    "helm": true,
    "html": true,
    "lua": true,
    "make": true,
    "proto": true,
    "sql": true,
    "swift": true,
    "toml": true,
    "vue": true,
    "xml": true,
